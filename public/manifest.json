{
  "manifest_version": 3,
  "name": "Sundhedsarkiv",
  "description": "Lokal eksport af dine egne sundhed.dk-data fra browseren.",
  "version": "0.1.0",
  "minimum_chrome_version": "116",
  "action": {
    "default_title": "Sundhedsarkiv"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "permissions": ["downloads", "sidePanel", "storage", "tabs", "unlimitedStorage"],
  "host_permissions": ["https://www.sundhed.dk/*", "https://sundhed.dk/*", "https://*.sundhed.dk/*"],
  "content_scripts": [
    {
      "matches": ["https://www.sundhed.dk/*", "https://sundhed.dk/*", "https://*.sundhed.dk/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["https://www.sundhed.dk/*", "https://sundhed.dk/*", "https://*.sundhed.dk/*"],
      "js": ["injected.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    }
  ]
}
