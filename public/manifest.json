{
  "manifest_version": 3,
  "name": "Sundhedsarkiv",
  "description": "Lokal eksport af dine egne sundhed.dk-data fra browseren.",
  "version": "0.1.0",
  "minimum_chrome_version": "116",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Sundhedsarkiv",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "permissions": ["downloads", "sidePanel", "storage", "tabs", "unlimitedStorage"],
  "host_permissions": ["https://www.sundhed.dk/*"],
  "content_scripts": [
    {
      "matches": ["https://www.sundhed.dk/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["https://www.sundhed.dk/*"],
      "js": ["injected.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    }
  ]
}
